{
    "routes": [
        {
            "route": "/api/*",
            "allowedRoles": [
                "anonymous"
            ]
        }
    ],
    "navigationFallback": {
        "rewrite": "/index.html",
        "exclude": [
            "/api/*",
            "/favicon/*",
            "/favicon.ico",
            "/style.css",
            "/robots.txt",
            "/sitemap.xml",
            "/og-image.png"
        ]
    },
    "platform": {
        "apiRuntime": "node:18"
    }
}